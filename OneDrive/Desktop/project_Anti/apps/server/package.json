{
    "name": "@beauty/server",
    "version": "1.0.0",
    "description": "Beauty eCommerce API",
    "main": "src/server.ts",
    "scripts": {
        "dev": "nodemon --watch 'src/**/*.ts' --exec ts-node src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "prisma:migrate": "prisma migrate dev --name init",
        "prisma:seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.3",
        "pg": "^8.11.3",
        "stripe": "^20.2.0"
    },
    "devDependencies": {
        "@prisma/client": "^5.10.2",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.19.30",
        "nodemon": "^3.0.2",
        "prisma": "^5.10.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
